<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="TicoBus.MAUI.Views.DetalleReservaPage"
    BackgroundColor="#F4F7FA"
    Title="Detalle">

    <ScrollView>
        <Frame
            Margin="20"
            Padding="22"
            BackgroundColor="White"
            CornerRadius="20"
            HasShadow="True">

            <VerticalStackLayout Spacing="14">

                <Label
                    Text="Detalle del viaje"
                    FontSize="28"
                    FontAttributes="Bold"
                    TextColor="#0D2B45"/>

                <Label Text="{Binding Reserva.Viaje.Ruta.Origen,StringFormat='Origen: {0}'}" TextColor="#111827" FontSize="16"/>
                <Label Text="{Binding Reserva.Viaje.Ruta.Destino,StringFormat='Destino: {0}'}" TextColor="#111827" FontSize="16"/>
                <Label Text="{Binding Reserva.Viaje.Unidad.Placa,StringFormat='Placa: {0}'}" TextColor="#111827" FontSize="16"/>
                <Label Text="{Binding Reserva.Viaje.Chofer.Nombre,StringFormat='Chofer: {0}'}" TextColor="#111827" FontSize="16"/>
                <Label Text="{Binding Reserva.Viaje.Chofer.Apellidos,StringFormat='Apellidos: {0}'}" TextColor="#111827" FontSize="16"/>
                <Label Text="{Binding Reserva.Viaje.FechaHoraSalida,StringFormat='Salida: {0:dd/MM/yyyy HH:mm}'}" TextColor="#111827" FontSize="16"/>
                <Label Text="{Binding Reserva.Viaje.FechaHoraLlegadaEstimada,StringFormat='Llegada estimada: {0:dd/MM/yyyy HH:mm}'}" TextColor="#111827" FontSize="16"/>
                <Label Text="{Binding Reserva.NumeroAsiento,StringFormat='Asiento asignado: {0}'}" TextColor="#111827" FontSize="16"/>

                <BoxView HeightRequest="1" BackgroundColor="#D1D5DB"/>

                <Label
                    Text="Resumen de pago"
                    FontSize="22"
                    FontAttributes="Bold"
                    TextColor="#0D2B45"/>

                <Label Text="{Binding Reserva.Viaje.Ruta.PrecioBase,StringFormat='Precio base: ₡{0:N2}'}" TextColor="#111827" FontSize="16"/>
                <Label Text="{Binding Reserva.MontoPagado,StringFormat='Total pagado: ₡{0:N2}'}" TextColor="#111827" FontSize="16"/>

            </VerticalStackLayout>
        </Frame>
    </ScrollView>
</ContentPage>