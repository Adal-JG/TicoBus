<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="TicoBus.MAUI.Views.MisReservasPage"
    BackgroundColor="#F4F7FA"
    Title="Mis Reservas">

    <Grid RowDefinitions="Auto,*">

        <Label
            Text="Mis Reservas"
            FontSize="30"
            FontAttributes="Bold"
            TextColor="#0D2B45"
            Margin="25,25,25,10"/>

        <CollectionView
            Grid.Row="1"
            ItemsSource="{Binding Reservas}"
            Margin="10">

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame
                        Margin="8"
                        Padding="20"
                        BackgroundColor="White"
                        CornerRadius="20"
                        HasShadow="True">

                        <VerticalStackLayout Spacing="10">

                            <Label
                                Text="{Binding Viaje.Estado}"
                                FontSize="22"
                                FontAttributes="Bold"
                                TextColor="#0D2B45"/>

                            <Label
                                Text="{Binding Viaje.Ruta.Origen,StringFormat='Origen: {0}'}"
                                FontSize="16"
                                TextColor="#111827"/>

                            <Label
                                Text="{Binding Viaje.Ruta.Destino,StringFormat='Destino: {0}'}"
                                FontSize="16"
                                TextColor="#111827"/>

                            <Label
                                Text="{Binding NumeroAsiento,StringFormat='Asiento asignado: {0}'}"
                                FontSize="16"
                                TextColor="#6B7280"/>

                            <Label
                                Text="{Binding Viaje.FechaHoraSalida,StringFormat='Fecha de salida: {0:dd/MM/yyyy HH:mm}'}"
                                FontSize="16"
                                TextColor="#6B7280"/>

                            <Button
                                Text="Ver detalle"
                                Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.VerDetalleCommand}"
                                CommandParameter="{Binding}"
                                BackgroundColor="#0D2B45"
                                TextColor="White"
                                CornerRadius="14"
                                HeightRequest="45"/>

                        </VerticalStackLayout>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </Grid>
</ContentPage>