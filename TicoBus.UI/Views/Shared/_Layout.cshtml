@{
    var nombre = Context.Session.GetString("Nombre");
    var rol = Context.Session.GetString("Rol");
    var autenticado = Context.Session.GetInt32("UsuarioId") != null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"] - TicoBus</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="~/css/custom.css" asp-append-version="true" />
    <style>
            body {
                background-color: #f4f6f9;
            }

            .sidebar {
                width: 260px;
                min-height: 100vh;
                background: #102a43;
                color: white;
                position: fixed;
                left: 0;
                top: 0;
                padding: 20px 15px;
                transition: all .3s ease;
            }

                .sidebar.collapsed {
                    width: 80px;
                }

                .sidebar .brand {
                    font-size: 24px;
                    font-weight: bold;
                    margin-bottom: 30px;
                    display: flex;
                    align-items: center;
                    gap: 10px;
                }

                .sidebar a {
                    color: #d9e2ec;
                    text-decoration: none;
                    display: flex;
                    align-items: center;
                    gap: 12px;
                    padding: 11px 14px;
                    border-radius: 8px;
                    margin-bottom: 6px;
                    white-space: nowrap;
                }

                    .sidebar a:hover {
                        background-color: #243b53;
                        color: white;
                    }

                .sidebar.collapsed .text-menu,
                .sidebar.collapsed .brand-text {
                    display: none;
                }

            .content {
                margin-left: 260px;
                min-height: 100vh;
                padding: 25px;
                transition: all .3s ease;
            }

                .content.expanded {
                    margin-left: 80px;
                }

            .topbar {
                background: white;
                padding: 15px 20px;
                border-radius: 12px;
                margin-bottom: 25px;
                box-shadow: 0 2px 8px rgba(0,0,0,.05);
            }

            .card {
                border-radius: 14px;
            }

            .footer {
                margin-top: 40px;
                padding: 15px;
                text-align: center;
                color: #6c757d;
                font-size: 14px;
            }

            .btn-toggle {
                border: none;
                background: #243b53;
                color: white;
                border-radius: 8px;
                padding: 6px 10px;
            }
    </style>
</head>

<body>

    @if (autenticado)
    {
        <div id="sidebar" class="sidebar">
            <div class="brand">
                <i class="bi bi-bus-front-fill"></i>
                <span class="brand-text">TicoBus</span>
            </div>

            @if (rol == "Administrador")
            {
                <a asp-controller="Dashboard" asp-action="Index"><i class="bi bi-speedometer2"></i><span class="text-menu">Panel principal</span></a>
                <a asp-controller="Choferes" asp-action="Index"><i class="bi bi-person-badge"></i><span class="text-menu">Choferes</span></a>
                <a asp-controller="Rutas" asp-action="Index"><i class="bi bi-signpost-2"></i><span class="text-menu">Rutas</span></a>
                <a asp-controller="Unidades" asp-action="Index"><i class="bi bi-bus-front"></i><span class="text-menu">Unidades</span></a>
                <a asp-controller="Viajes" asp-action="Index"><i class="bi bi-map"></i><span class="text-menu">Viajes</span></a>
                <a asp-controller="ViajesCancelados" asp-action="Index"><i class="bi bi-x-octagon"></i><span class="text-menu">Viajes cancelados</span></a>
            }

            @if (rol == "Chofer")
            {
                <a asp-controller="Dashboard" asp-action="Index"><i class="bi bi-speedometer2"></i><span class="text-menu">Panel principal</span></a>
                <a asp-controller="Pasajeros" asp-action="Index"><i class="bi bi-people"></i><span class="text-menu">Pasajeros</span></a>
                <a asp-controller="Rutas" asp-action="Index"><i class="bi bi-signpost-2"></i><span class="text-menu">Rutas</span></a>
                <a asp-controller="Unidades" asp-action="Index"><i class="bi bi-bus-front"></i><span class="text-menu">Unidades</span></a>
                <a asp-controller="Viajes" asp-action="Index"><i class="bi bi-map"></i><span class="text-menu">Viajes</span></a>
                <a asp-controller="ViajesEnCurso" asp-action="Index"><i class="bi bi-play-circle"></i><span class="text-menu">Viajes en curso</span></a>
            }

            @if (rol == "Pasajero")
            {
                <a asp-controller="MisViajes" asp-action="Index"><i class="bi bi-ticket-perforated"></i><span class="text-menu">Mis viajes</span></a>
            }

            <hr />

            <a asp-controller="Clave" asp-action="Cambiar"><i class="bi bi-key"></i><span class="text-menu">Cambiar clave</span></a>
            <a asp-controller="Login" asp-action="Logout"><i class="bi bi-box-arrow-right"></i><span class="text-menu">Cerrar sesión</span></a>
        </div>

        <div id="content" class="content">
            <div class="topbar d-flex justify-content-between align-items-center">
                <button class="btn-toggle" onclick="toggleMenu()">
                    <i class="bi bi-list"></i>
                </button>

                <div>
                    <strong>@nombre</strong>
                    <span class="text-muted">(@rol)</span>
                </div>
            </div>

            <main>
                @RenderBody()
            </main>

            <div class="footer">
                TicoBus © @DateTime.Now.Year · Sistema de Gestión de Transporte Interurbano
            </div>
        </div>
    }
    else
    {
        @RenderBody()
    }

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <script>
            function toggleMenu() {
                document.getElementById("sidebar").classList.toggle("collapsed");
                document.getElementById("content").classList.toggle("expanded");
            }
    </script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>