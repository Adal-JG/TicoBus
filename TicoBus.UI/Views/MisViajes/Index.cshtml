@model List<TicoBus.Model.Reserva>

@{
    ViewData["Title"] = "Mis Viajes";
}

<div class="page-header">
    <div>
        <h2>Mis Viajes</h2>
        <p class="text-muted mb-0">
            Historial de reservas realizadas.
        </p>
    </div>
</div>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger shadow-sm">
        @TempData["Error"]
    </div>
}

<div class="card app-card">
    <div class="card-body table-wrapper">

        @if (!Model.Any())
        {
            <div class="alert alert-info">
                No tiene viajes registrados.
            </div>
        }
        else
        {
            <div class="table-responsive">

                <table class="table table-hover align-middle app-table w-100">

                    <thead>

                        <tr>

                            <th>Ruta</th>
                            <th>Salida</th>
                            <th>Asiento</th>
                            <th>Estado</th>
                            <th>Monto</th>
                            <th class="text-end">Acciones</th>

                        </tr>

                    </thead>

                    <tbody>

                        @foreach (var item in Model)
                        {
                            <tr>

                                <td>
                                    @item.Viaje?.Ruta?.Origen →
                                    @item.Viaje?.Ruta?.Destino
                                </td>

                                <td>
                                    @item.Viaje?.FechaHoraSalida.ToString("dd/MM/yyyy HH:mm")
                                </td>

                                <td>
                                    @item.NumeroAsiento
                                </td>

                                <td>

                                    @switch (item.Viaje?.Estado)
                                    {
                                        case TicoBus.Model.EstadoViaje.Programado:
                                            <span class="badge bg-primary">Programado</span>
                                            break;

                                        case TicoBus.Model.EstadoViaje.EnCurso:
                                            <span class="badge bg-success">En curso</span>
                                            break;

                                        case TicoBus.Model.EstadoViaje.Completado:
                                            <span class="badge bg-secondary">Completado</span>
                                            break;

                                        case TicoBus.Model.EstadoViaje.Cancelado:
                                            <span class="badge bg-danger">Cancelado</span>
                                            break;
                                    }

                                </td>

                                <td>
                                    ₡@item.MontoPagado.ToString("N2")
                                </td>

                                <td class="text-end">

                                    <a asp-action="Detalle"
                                           asp-route-id="@item.Id"
                                           class="btn btn-sm btn-primary">

                                        <i class="bi bi-eye"></i>
                                        Ver detalle

                                    </a>

                                </td>

                            </tr>
                        }

                    </tbody>

                </table>

            </div>
        }

    </div>
</div>