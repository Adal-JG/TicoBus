@model TicoBus.UI.Models.ViajeViewModel
@using System.Text.Json

@{
    ViewData["Title"] = "Nuevo viaje";
    var duraciones = JsonSerializer.Serialize(ViewBag.DuracionesRutas);
}

<div class="page-header">
    <div>
        <h2>Nuevo Viaje</h2>
        <p class="text-muted mb-0">Complete la información para programar un nuevo viaje.</p>
    </div>
</div>

<div class="card app-card">
    <div class="card-body">

        <form asp-action="Create" method="post">

            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

            <div class="mb-3">
                <label asp-for="RutaId" class="form-label">Ruta</label>
                <select asp-for="RutaId" asp-items="ViewBag.Rutas" class="form-select" id="RutaId">
                    <option value="">Seleccione una ruta</option>
                </select>
                <span asp-validation-for="RutaId" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="UnidadId" class="form-label">Unidad</label>
                <select asp-for="UnidadId" asp-items="ViewBag.Unidades" class="form-select">
                    <option value="">Seleccione una unidad</option>
                </select>
                <span asp-validation-for="UnidadId" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="ChoferId" class="form-label">Chofer</label>
                <select asp-for="ChoferId" asp-items="ViewBag.Choferes" class="form-select">
                    <option value="">Seleccione un chofer</option>
                </select>
                <span asp-validation-for="ChoferId" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="FechaHoraSalida" class="form-label">Fecha y hora de salida</label>
                <input asp-for="FechaHoraSalida"
                       type="datetime-local"
                       class="form-control"
                       id="FechaHoraSalida"
                       value="@Model.FechaHoraSalida.ToString("yyyy-MM-ddTHH:mm")" />
                <span asp-validation-for="FechaHoraSalida" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="FechaHoraLlegadaEstimada" class="form-label">Fecha y hora estimada de llegada</label>
                <input asp-for="FechaHoraLlegadaEstimada"
                       type="datetime-local"
                       class="form-control"
                       id="FechaHoraLlegadaEstimada"
                       value="@Model.FechaHoraLlegadaEstimada.ToString("yyyy-MM-ddTHH:mm")" />
                <small class="text-muted">
                    La hora mínima se calcula según la duración de la ruta. Puede elegir una hora igual o posterior.
                </small>
                <span asp-validation-for="FechaHoraLlegadaEstimada" class="text-danger"></span>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-save"></i> Guardar
                </button>

                <a asp-action="Index" class="btn btn-secondary">
                    <i class="bi bi-arrow-left"></i> Volver
                </a>
            </div>

        </form>

    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        const duracionesRutas = @Html.Raw(duraciones);

        function calcularLlegadaMinima() {
            const rutaId = parseInt(document.getElementById("RutaId").value);
            const salidaInput = document.getElementById("FechaHoraSalida");
            const llegadaInput = document.getElementById("FechaHoraLlegadaEstimada");

            if (!rutaId || !salidaInput.value) {
                return;
            }

            const ruta = duracionesRutas.find(r => r.id === rutaId);

            if (!ruta) {
                return;
            }

            const salida = new Date(salidaInput.value);
            salida.setMinutes(salida.getMinutes() + ruta.minutos);

            const llegadaMinima = formatoDateTimeLocal(salida);

            llegadaInput.value = llegadaMinima;
            llegadaInput.min = llegadaMinima;
        }

        function validarLlegadaMinima() {
            const llegadaInput = document.getElementById("FechaHoraLlegadaEstimada");

            if (llegadaInput.min && llegadaInput.value < llegadaInput.min) {
                llegadaInput.value = llegadaInput.min;
            }
        }

        function formatoDateTimeLocal(fecha) {
            const year = fecha.getFullYear();
            const month = String(fecha.getMonth() + 1).padStart(2, "0");
            const day = String(fecha.getDate()).padStart(2, "0");
            const hours = String(fecha.getHours()).padStart(2, "0");
            const minutes = String(fecha.getMinutes()).padStart(2, "0");

            return `${year}-${month}-${day}T${hours}:${minutes}`;
        }

        document.getElementById("RutaId").addEventListener("change", calcularLlegadaMinima);
        document.getElementById("FechaHoraSalida").addEventListener("change", calcularLlegadaMinima);
        document.getElementById("FechaHoraLlegadaEstimada").addEventListener("change", validarLlegadaMinima);
    </script>
}