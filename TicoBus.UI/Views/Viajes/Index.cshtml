@model List<TicoBus.Model.Viaje>

@{
    ViewData["Title"] = "Viajes";
}

<div class="page-header">
    <div>
        <h2>Gestión de Viajes</h2>
        <p class="text-muted mb-0">Programación, inicio y cancelación de viajes.</p>
    </div>

    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-circle"></i> Nuevo viaje
    </a>
</div>

@if (TempData["Exito"] != null)
{
    <div class="alert alert-success shadow-sm">@TempData["Exito"]</div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger shadow-sm">@TempData["Error"]</div>
}

<form method="get" class="filter-card">
    <div class="row g-2 align-items-center">
        <div class="col-md-10">
            <input type="text"
                   name="filtro"
                   value="@ViewBag.Filtro"
                   class="form-control"
                   placeholder="Buscar por ruta, destino o fecha..." />
        </div>

        <div class="col-md-2">
            <button class="btn btn-dark w-100" type="submit">
                <i class="bi bi-search"></i> Buscar
            </button>
        </div>
    </div>
</form>

<div class="card app-card">
    <div class="card-body table-wrapper">

        @if (Model.Count == 0)
        {
            <div class="alert alert-info">
                No hay viajes registrados.
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle app-table w-100">
                    <thead>
                        <tr>
                            <th>Número</th>
                            <th>Ruta</th>
                            <th>Unidad</th>
                            <th>Chofer</th>
                            <th>Salida</th>
                            <th>Llegada estimada</th>
                            <th>Estado</th>
                            <th class="text-end">Acciones</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>#@item.Id</td>
                                <td>@item.Ruta?.Origen → @item.Ruta?.Destino</td>
                                <td>@item.Unidad?.Placa</td>
                                <td>@item.Chofer?.Nombre @item.Chofer?.Apellidos</td>
                                <td>@item.FechaHoraSalida.ToString("dd/MM/yyyy HH:mm")</td>
                                <td>@item.FechaHoraLlegadaEstimada.ToString("dd/MM/yyyy HH:mm")</td>
                                <td>
                                    @if (item.Estado == TicoBus.Model.EstadoViaje.Programado)
                                    {
                                        <span class="badge bg-primary">Programado</span>
                                    }
                                    else if (item.Estado == TicoBus.Model.EstadoViaje.EnCurso)
                                    {
                                        <span class="badge bg-success">En curso</span>
                                    }
                                    else if (item.Estado == TicoBus.Model.EstadoViaje.Completado)
                                    {
                                        <span class="badge bg-secondary">Completado</span>
                                    }
                                    else if (item.Estado == TicoBus.Model.EstadoViaje.Cancelado)
                                    {
                                        <span class="badge bg-danger">Cancelado</span>
                                    }
                                </td>
                                <td class="text-end">
                                    <div class="action-buttons">
                                        @if (item.Estado == TicoBus.Model.EstadoViaje.Programado)
                                        {
                                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">
                                                <i class="bi bi-pencil"></i> Editar
                                            </a>

                                            <form asp-action="Iniciar" method="post" class="d-inline">
                                                <input type="hidden" name="id" value="@item.Id" />
                                                <button type="submit"
                                                        class="btn btn-sm btn-success"
                                                        onclick="return confirm('¿Desea iniciar este viaje?');">
                                                    <i class="bi bi-play-circle"></i> Iniciar
                                                </button>
                                            </form>

                                            <a asp-action="Cancelar" asp-route-id="@item.Id" class="btn btn-sm btn-danger">
                                                <i class="bi bi-x-circle"></i> Cancelar
                                            </a>
                                        }
                                        else
                                        {
                                            <span class="text-muted">Sin acciones</span>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }

    </div>
</div>