@model TicoBus.UI.Models.UnidadViewModel

@{
    ViewData["Title"] = "Editar unidad";
}

<div class="page-header">
    <div>
        <h2>Editar Unidad</h2>
        <p class="text-muted mb-0">Modifique los datos de la unidad seleccionada.</p>
    </div>
</div>

<div class="card app-card">
    <div class="card-body">

        <form asp-action="Edit" method="post">

            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

            <input type="hidden" asp-for="Id" />

            <div class="mb-3">
                <label asp-for="Placa" class="form-label">Placa</label>
                <input asp-for="Placa" class="form-control" />
                <span asp-validation-for="Placa" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Modelo" class="form-label">Modelo</label>
                <input asp-for="Modelo" class="form-control" />
                <span asp-validation-for="Modelo" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="AnioFabricacion" class="form-label">Año de fabricación</label>
                <input asp-for="AnioFabricacion" class="form-control" />
                <span asp-validation-for="AnioFabricacion" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="CapacidadPasajeros" class="form-label">Capacidad de pasajeros</label>
                <input asp-for="CapacidadPasajeros" class="form-control" />
                <span asp-validation-for="CapacidadPasajeros" class="text-danger"></span>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-warning">
                    <i class="bi bi-save"></i> Actualizar
                </button>

                <a asp-action="Index" class="btn btn-secondary">
                    <i class="bi bi-arrow-left"></i> Volver
                </a>
            </div>

        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}