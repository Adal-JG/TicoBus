@model List<TicoBus.Model.Ruta>

@{
    ViewData["Title"] = "Rutas";
}

<div class="page-header">

    <div>
        <h2>Catálogo de Rutas</h2>
        <p class="text-muted mb-0">
            Administración de rutas disponibles.
        </p>
    </div>

    <a asp-action="Create" class="btn btn-primary mb-3">
        <i class="bi bi-plus-circle"></i>
        Nueva ruta
    </a>

</div>

@if (TempData["Exito"] != null)
{
    <div class="alert alert-success shadow-sm">@TempData["Exito"]</div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger shadow-sm">@TempData["Error"]</div>
}

<form method="get" class="filter-card">
    <div class="card-body">
        <div class="row g-2">
            <div class="col-md-10">
                <input type="text"
                       name="filtro"
                       value="@ViewBag.Filtro"
                       class="form-control"
                       placeholder="Buscar por nombre o destino..." />
            </div>

            <div class="col-md-2">
                <button class="btn btn-dark w-100" type="submit">
                    <i class="bi bi-search"></i> Buscar
                </button>
            </div>
        </div>
    </div>
</form>

<div class="card app-card">
    <div class="card-body table-wrapper">

        @if (Model.Count == 0)
        {
            <div class="alert alert-info">
                No hay rutas registradas.
            </div>
        }
        else
        {
            <div class="table-responsive">

                <table class="table table-hover align-middle app-table w-100">

                    <thead>
                        <tr>
                            <th>Nombre</th>
                            <th>Origen</th>
                            <th>Destino</th>
                            <th>Duración estimada</th>
                            <th>Precio base</th>
                            <th class="text-end">Acciones</th>
                        </tr>
                    </thead>

                    <tbody>

                        @foreach (var item in Model)
                        {
                            <tr>

                                <td>@item.Nombre</td>

                                <td>@item.Origen</td>

                                <td>@item.Destino</td>

                                <td>
                                    @($"{(int)item.DuracionEstimada.TotalHours:00}:{item.DuracionEstimada.Minutes:00}")
                                </td>

                                <td>
                                    ₡@item.PrecioBase.ToString("N2")
                                </td>

                                <td class="text-end">

                                    <div class="action-buttons">

                                        <a asp-action="Edit"
                                               asp-route-id="@item.Id"
                                               class="btn btn-sm btn-warning">

                                            <i class="bi bi-pencil"></i> Editar

                                        </a>

                                        <form asp-action="Delete"
                                              method="post"
                                              class="d-inline">

                                            <input type="hidden"
                                                   name="id"
                                                   value="@item.Id" />

                                            <button type="submit"
                                                    class="btn btn-sm btn-danger"
                                                    onclick="return confirm('¿Seguro que desea eliminar esta ruta?');">

                                                <i class="bi bi-trash"></i> Eliminar

                                            </button>

                                        </form>

                                    </div>

                                </td>

                            </tr>
                        }

                    </tbody>

                </table>

            </div>
        }

    </div>
</div>