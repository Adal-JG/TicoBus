@using TicoBus.Model

@{
    ViewData["Title"] = "Panel del Chofer";

    var viajesHoy = ViewBag.ViajesHoy as List<Viaje> ?? new List<Viaje>();
    var proximoViaje = ViewBag.ProximoViaje as Viaje;
}

<div class="page-header">
    <div>
        <h2>Panel del Chofer</h2>
        <p class="text-muted mb-0">Bienvenido, @ViewBag.Nombre.</p>
    </div>
</div>

<div class="row g-4 mb-4">

    <div class="col-md-4">
        <div class="card stat-card bg-tb-primary">
            <div class="card-body">
                <div class="stat-label">Viajes para hoy</div>
                <div class="stat-number">@ViewBag.TotalViajesHoy</div>
                <i class="bi bi-calendar-event stat-icon"></i>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card stat-card bg-tb-green">
            <div class="card-body">
                <div class="stat-label">Pasajeros registrados</div>
                <div class="stat-number">@ViewBag.PasajerosRegistrados</div>
                <i class="bi bi-people stat-icon"></i>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card stat-card bg-tb-blue">
            <div class="card-body">
                <div class="stat-label">Asientos disponibles</div>
                <div class="stat-number">@ViewBag.AsientosDisponibles</div>
                <i class="bi bi-grid-3x3-gap stat-icon"></i>
            </div>
        </div>
    </div>

</div>

@if (proximoViaje != null)
{
    <div class="card app-card mb-4">
        <div class="card-body">
            <h5>Próximo viaje</h5>
            <hr />

            <p><strong>Ruta:</strong> @proximoViaje.Ruta?.Origen → @proximoViaje.Ruta?.Destino</p>
            <p><strong>Unidad:</strong> @proximoViaje.Unidad?.Placa</p>
            <p><strong>Salida:</strong> @proximoViaje.FechaHoraSalida.ToString("dd/MM/yyyy HH:mm")</p>

            <a asp-controller="Viajes" asp-action="Index" class="btn btn-primary">
                <i class="bi bi-map"></i> Ver viajes
            </a>
        </div>
    </div>
}
else
{
    <div class="alert alert-info shadow-sm">
        No tiene viajes programados próximos.
    </div>
}

<div class="card app-card">
    <div class="card-body table-wrapper">

        <h5 class="mb-3">Viajes asignados para hoy</h5>

        @if (!viajesHoy.Any())
        {
            <div class="alert alert-info">
                No tiene viajes asignados para hoy.
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle app-table w-100">
                    <thead>
                        <tr>
                            <th>Ruta</th>
                            <th>Unidad</th>
                            <th>Salida</th>
                            <th>Llegada estimada</th>
                            <th>Estado</th>
                            <th>Ocupación</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var item in viajesHoy)
                        {
                            var ocupados = item.Reservas?.Count(r => r.Activa) ?? 0;
                            var capacidad = item.Unidad?.CapacidadPasajeros ?? 0;

                            <tr>
                                <td>@item.Ruta?.Origen → @item.Ruta?.Destino</td>
                                <td>@item.Unidad?.Placa</td>
                                <td>@item.FechaHoraSalida.ToString("HH:mm")</td>
                                <td>@item.FechaHoraLlegadaEstimada.ToString("HH:mm")</td>
                                <td>
                                    @if (item.Estado == EstadoViaje.Programado)
                                    {
                                        <span class="badge bg-primary">Programado</span>
                                    }
                                    else if (item.Estado == EstadoViaje.EnCurso)
                                    {
                                        <span class="badge bg-success">En curso</span>
                                    }
                                    else if (item.Estado == EstadoViaje.Completado)
                                    {
                                        <span class="badge bg-secondary">Completado</span>
                                    }
                                </td>
                                <td>@ocupados / @capacidad</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }

    </div>
</div>