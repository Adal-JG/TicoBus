@using System.Text.Json
@using TicoBus.Model

@{
    ViewData["Title"] = "Panel del Chofer";

    var viajesHoyJson = ViewBag.ViajesHoyJson as string ?? "[]";
    JsonElement viajesHoy;

    try
    {
        viajesHoy = JsonDocument.Parse(viajesHoyJson).RootElement.Clone();
    }
    catch
    {
        viajesHoy = JsonDocument.Parse("[]").RootElement.Clone();
    }
}

<div class="page-header">
    <div>
        <h2>Panel del Chofer</h2>
        <p class="text-muted mb-0">Bienvenido, @ViewBag.Nombre.</p>
    </div>
</div>

<div class="row g-4 mb-4">
    <div class="col-md-4">
        <div class="card stat-card bg-tb-primary">
            <div class="card-body">
                <div class="stat-label">Viajes para hoy</div>
                <div class="stat-number">@ViewBag.TotalViajesHoy</div>
                <i class="bi bi-calendar-event stat-icon"></i>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card stat-card bg-tb-green">
            <div class="card-body">
                <div class="stat-label">Pasajeros registrados</div>
                <div class="stat-number">@ViewBag.PasajerosRegistrados</div>
                <i class="bi bi-people stat-icon"></i>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card stat-card bg-tb-blue">
            <div class="card-body">
                <div class="stat-label">Asientos disponibles</div>
                <div class="stat-number">@ViewBag.AsientosDisponibles</div>
                <i class="bi bi-grid-3x3-gap stat-icon"></i>
            </div>
        </div>
    </div>
</div>

<div class="card app-card">
    <div class="card-body table-wrapper">
        <h5 class="mb-3">Viajes asignados para hoy</h5>

        @if (viajesHoy.ValueKind != JsonValueKind.Array || viajesHoy.GetArrayLength() == 0)
        {
            <div class="alert alert-info">
                No tiene viajes asignados para hoy.
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle app-table w-100">
                    <thead>
                        <tr>
                            <th>Ruta</th>
                            <th>Unidad</th>
                            <th>Salida</th>
                            <th>Llegada estimada</th>
                            <th>Estado</th>
                            <th>Ocupación</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var item in viajesHoy.EnumerateArray())
                        {
                            var ruta = item.TryGetProperty("ruta", out var rutaProp) ? rutaProp : default;
                            var unidad = item.TryGetProperty("unidad", out var unidadProp) ? unidadProp : default;
                            var reservas = item.TryGetProperty("reservas", out var reservasProp) ? reservasProp : default;

                            var origen = ruta.ValueKind != JsonValueKind.Undefined && ruta.TryGetProperty("origen", out var origenProp)
                                ? origenProp.GetString()
                                : "";

                            var destino = ruta.ValueKind != JsonValueKind.Undefined && ruta.TryGetProperty("destino", out var destinoProp)
                                ? destinoProp.GetString()
                                : "";

                            var placa = unidad.ValueKind != JsonValueKind.Undefined && unidad.TryGetProperty("placa", out var placaProp)
                                ? placaProp.GetString()
                                : "";

                            var capacidad = unidad.ValueKind != JsonValueKind.Undefined && unidad.TryGetProperty("capacidadPasajeros", out var capacidadProp)
                                ? capacidadProp.GetInt32()
                                : 0;

                            var ocupados = 0;

                            if (reservas.ValueKind == JsonValueKind.Array)
                            {
                                foreach (var reserva in reservas.EnumerateArray())
                                {
                                    if (reserva.TryGetProperty("activa", out var activaProp) && activaProp.GetBoolean())
                                    {
                                        ocupados++;
                                    }
                                }
                            }

                            var salida = item.TryGetProperty("fechaHoraSalida", out var salidaProp)
                                ? salidaProp.GetDateTime().ToString("HH:mm")
                                : "";

                            var llegada = item.TryGetProperty("fechaHoraLlegadaEstimada", out var llegadaProp)
                                ? llegadaProp.GetDateTime().ToString("HH:mm")
                                : "";

                            var estado = item.TryGetProperty("estado", out var estadoProp)
                                ? estadoProp.GetInt32()
                                : 0;

                            <tr>
                                <td>@origen → @destino</td>
                                <td>@placa</td>
                                <td>@salida</td>
                                <td>@llegada</td>
                                <td>
                                    @if (estado == 1)
                                    {
                                        <span class="badge bg-primary">Programado</span>
                                    }
                                    else if (estado == 2)
                                    {
                                        <span class="badge bg-success">En curso</span>
                                    }
                                    else if (estado == 3)
                                    {
                                        <span class="badge bg-secondary">Completado</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-info">Estado @estado</span>
                                    }
                                </td>
                                <td>@ocupados / @capacidad</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>