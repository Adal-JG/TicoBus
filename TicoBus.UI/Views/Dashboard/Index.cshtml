@{
    ViewData["Title"] = "Panel principal";
}

<div class="container mt-4">

    <div class="card shadow-sm">
        <div class="card-body">
            <h2>Bienvenido, @ViewBag.Nombre</h2>
            <p class="text-muted">Rol actual: @ViewBag.Rol</p>

            <hr />

            <p>Has iniciado sesión correctamente en TicoBus.</p>

            <a asp-controller="Login" asp-action="Logout" class="btn btn-danger">
                Cerrar sesión
            </a>
        </div>
    </div>

</div>