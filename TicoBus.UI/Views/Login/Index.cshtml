@model TicoBus.UI.Models.LoginViewModel

@{
    ViewData["Title"] = "Iniciar sesión";
}

<div class="login-page">
    <div class="login-card">

        <div class="login-logo">
            <i class="bi bi-bus-front-fill"></i>
        </div>

        <h2>TicoBus</h2>
        <p>Sistema de Gestión de Transporte Interurbano</p>

        @if (ViewBag.Error != null)
        {
            <div class="alert alert-danger">
                @ViewBag.Error
            </div>
        }

        <form asp-action="Index" method="post">

            <div class="mb-3">
                <label asp-for="NombreUsuario" class="form-label">Usuario</label>
                <input asp-for="NombreUsuario" class="form-control" placeholder="Ingrese su usuario" />
                <span asp-validation-for="NombreUsuario" class="text-danger"></span>
            </div>

            <div class="mb-4">
                <label asp-for="Clave" class="form-label">Clave</label>
                <input asp-for="Clave" class="form-control" placeholder="Ingrese su clave" />
                <span asp-validation-for="Clave" class="text-danger"></span>
            </div>

            <button type="submit" class="btn btn-primary w-100">
                <i class="bi bi-box-arrow-in-right"></i> Ingresar
            </button>

        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}